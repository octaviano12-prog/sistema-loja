        </a>
        <a href="#" onclick="navigate('categories')" class="nav-item flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700" data-page="categories">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
          Categorias
        </a>
        <a href="#" onclick="navigate('stock')" class="nav-item flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700" data-page="stock">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
          Estoque
        </a>
        <div class="mb-2 mt-4"><p class="text-xs font-semibold text-gray-400 uppercase px-3 mb-1">Pessoas</p></div>
        <a href="#" onclick="navigate('customers')" class="nav-item flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-700" data-page="customers">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>

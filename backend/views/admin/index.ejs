                <div><label class="text-sm font-medium text-gray-700">Gênero</label><select name="gender" class="input-field mt-1"><option value="">Selecione</option><option value="feminino" ${product.gender === 'feminino' ? 'selected' : ''}>Feminino</option><option value="masculino" ${product.gender === 'masculino' ? 'selected' : ''}>Masculino</option><option value="infantil" ${product.gender === 'infantil' ? 'selected' : ''}>Infantil</option><option value="unissex" ${product.gender === 'unissex' ? 'selected' : ''}>Unissex</option></select></div>
                <div class="sm:col-span-2"><label class="text-sm font-medium text-gray-700">Descrição</label><textarea name="description" class="input-field mt-1" rows="3">${product.description || ''}</textarea></div>
                <div class="flex gap-4 items-center"><label class="flex items-center gap-2 text-sm"><input type="checkbox" name="is_featured" ${product.is_featured ? 'checked' : ''}> Destaque</label><label class="flex items-center gap-2 text-sm"><input type="checkbox" name="is_promotional" ${product.is_promotional ? 'checked' : ''}> Promoção</label><label class="flex items-center gap-2 text-sm"><input type="checkbox" name="is_new" ${product.is_new ? 'checked' : ''}> Novo</label></div>
                <div><label class="text-sm font-medium text-gray-700">Status</label><select name="status" class="input-field mt-1"><option value="active" ${product.status === 'active' ? 'selected' : ''}>Ativo</option><option value="inactive" ${product.status === 'inactive' ? 'selected' : ''}>Inativo</option><option value="draft" ${product.status === 'draft' ? 'selected' : ''}>Rascunho</option></select></div>
              </div>
              <div class="flex justify-end gap-2 mt-4">
                <button type="button" onclick="this.closest('.modal-overlay').remove()" class="btn-secondary">Cancelar</button>
                <button type="submit" class="btn-primary">Salvar</button>
              </div>
            </form>
          </div>
        </div>`;
    }

    async function saveProduct(e, id) {
      e.preventDefault();
      const form = e.target;
      const data = Object.fromEntries(new FormData(form));
      data.is_featured = form.is_featured.checked ? 1 : 0;
      data.is_promotional = form.is_promotional.checked ? 1 : 0;
      data.is_new = form.is_new.checked ? 1 : 0;
      try {
        if (id) { await api(`/api/products/${id}`, { method: 'PUT', body: JSON.stringify(data) }); }
        else { await api('/api/products', { method: 'POST', body: JSON.stringify(data) }); }
        toast('Produto salvo com sucesso!');
        document.querySelector('.modal-overlay').remove();
        renderProducts();
      } catch (err) { toast(err.message, 'error'); }
    }

    async function deleteProduct(id) {
      if (!confirm('Excluir este produto?')) return;
      try { await api(`/api/products/${id}`, { method: 'DELETE' }); toast('Produto excluído'); renderProducts(); } catch (err) { toast(err.message, 'error'); }
    }


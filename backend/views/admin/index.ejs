        <div class="card overflow-hidden">
          <div class="table-container">
            <table class="w-full text-sm"><thead class="bg-gray-50 border-b"><tr><th class="text-left p-3 font-medium text-gray-600">Número</th><th class="text-left p-3 font-medium text-gray-600 hidden sm:table-cell">Pedido</th><th class="text-left p-3 font-medium text-gray-600 hidden md:table-cell">Cliente</th><th class="text-right p-3 font-medium text-gray-600">Valor</th><th class="text-center p-3 font-medium text-gray-600">Status</th><th class="text-center p-3 font-medium text-gray-600">Data</th></tr></thead>
            <tbody>${data.invoices.map(inv => `<tr class="border-b hover:bg-gray-50"><td class="p-3 font-medium">${inv.number || '-'}</td><td class="p-3 text-gray-600 hidden sm:table-cell">${inv.order_number || '-'}</td><td class="p-3 text-gray-600 hidden md:table-cell">${inv.customer_name || '-'}</td><td class="p-3 text-right">${formatCurrency(inv.total_value)}</td><td class="p-3 text-center">${statusBadge(inv.status)}</td><td class="p-3 text-center text-xs">${formatDate(inv.issued_at || inv.created_at)}</td></tr>`).join('') || '<tr><td colspan="6" class="p-8 text-center text-gray-400">Nenhuma nota fiscal emitida</td></tr>'}</tbody></table>
          </div>
        </div>`;
    }

    // ===== COUPONS =====
    async function renderCoupons() {
      const coupons = await api('/api/coupons');
      document.getElementById('pageContent').innerHTML = `
        <div class="flex justify-between items-center mb-4"><div></div><button onclick="openCouponModal()" class="btn-primary">+ Novo Cupom</button></div>
        <div class="card overflow-hidden">
          <div class="table-container">
            <table class="w-full text-sm"><thead class="bg-gray-50 border-b"><tr><th class="text-left p-3 font-medium text-gray-600">Código</th><th class="text-left p-3 font-medium text-gray-600">Tipo</th><th class="text-right p-3 font-medium text-gray-600">Valor</th><th class="text-center p-3 font-medium text-gray-600">Usos</th><th class="text-center p-3 font-medium text-gray-600">Status</th><th class="text-center p-3 font-medium text-gray-600">Ações</th></tr></thead>
            <tbody>${coupons.map(c => `<tr class="border-b hover:bg-gray-50"><td class="p-3 font-medium font-mono">${c.code}</td><td class="p-3">${c.type === 'percentage' ? 'Porcentagem' : 'Valor fixo'}</td><td class="p-3 text-right">${c.type === 'percentage' ? c.value + '%' : formatCurrency(c.value)}</td><td class="p-3 text-center">${c.used_count}/${c.max_uses || '∞'}</td><td class="p-3 text-center">${statusBadge(c.status)}</td><td class="p-3 text-center"><button onclick="deleteCoupon(${c.id})" class="text-red-600 text-xs">Excluir</button></td></tr>`).join('') || '<tr><td colspan="6" class="p-8 text-center text-gray-400">Nenhum cupom</td></tr>'}</tbody></table>
          </div>
        </div>
        <div id="couponModal"></div>`;
    }

    function openCouponModal() {
      document.getElementById('couponModal').innerHTML = `
        <div class="modal-overlay" onclick="if(event.target===this)this.remove()"><div class="modal-content">
          <h3 class="text-lg font-semibold mb-4">Novo Cupom</h3>
          <form onsubmit="saveCoupon(event)">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div><label class="text-sm font-medium text-gray-700">Código *</label><input name="code" class="input-field mt-1 uppercase" required></div>
              <div><label class="text-sm font-medium text-gray-700">Tipo *</label><select name="type" class="input-field mt-1"><option value="percentage">Porcentagem (%)</option><option value="fixed">Valor Fixo (R$)</option></select></div>
              <div><label class="text-sm font-medium text-gray-700">Valor *</label><input name="value" type="number" step="0.01" class="input-field mt-1" required></div>
              <div><label class="text-sm font-medium text-gray-700">Compra Mínima</label><input name="min_purchase" type="number" step="0.01" class="input-field mt-1" value="0"></div>
              <div><label class="text-sm font-medium text-gray-700">Data Início</label><input name="start_date" type="date" class="input-field mt-1"></div>
              <div><label class="text-sm font-medium text-gray-700">Data Fim</label><input name="end_date" type="date" class="input-field mt-1"></div>
              <div><label class="text-sm font-medium text-gray-700">Máx. Usos</label><input name="max_uses" type="number" class="input-field mt-1"></div>
            </div>
            <div class="flex justify-end gap-2 mt-4"><button type="button" onclick="this.closest('.modal-overlay').remove()" class="btn-secondary">Cancelar</button><button type="submit" class="btn-primary">Salvar</button></div>
          </form>
        </div></div>`;
    }

    async function saveCoupon(e) {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(e.target));
      try { await api('/api/coupons', { method: 'POST', body: JSON.stringify(data) }); toast('Cupom criado'); document.querySelector('.modal-overlay').remove(); renderCoupons(); } catch (err) { toast(err.message, 'error'); }
    }

    async function deleteCoupon(id) { if (!confirm('Excluir?')) return; try { await api(`/api/coupons/${id}`, { method: 'DELETE' }); toast('Excluído'); renderCoupons(); } catch (err) { toast(err.message, 'error'); } }

    // ===== SETTINGS =====
    async function renderSettings() {
      const data = await api('/api/settings');
      const c = data.company || {};
      document.getElementById('pageContent').innerHTML = `
        <form onsubmit="saveSettings(event)" class="space-y-6">
          <div class="card p-4">
            <h3 class="font-semibold mb-4">Dados da Empresa</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div><label class="text-sm font-medium text-gray-700">Nome da Loja</label><input name="name" value="${c.name || ''}" class="input-field mt-1"></div>
              <div><label class="text-sm font-medium text-gray-700">Nome Fantasia</label><input name="trade_name" value="${c.trade_name || ''}" class="input-field mt-1"></div>
              <div><label class="text-sm font-medium text-gray-700">CNPJ</label><input name="cnpj" value="${c.cnpj || ''}" class="input-field mt-1"></div>
              <div><label class="text-sm font-medium text-gray-700">Telefone</label><input name="phone" value="${c.phone || ''}" class="input-field mt-1"></div>
              <div><label class="text-sm font-medium text-gray-700">Email</label><input name="email" value="${c.email || ''}" class="input-field mt-1"></div>
              <div><label class="text-sm font-medium text-gray-700">WhatsApp</label><input name="whatsapp" value="${c.whatsapp || ''}" class="input-field mt-1"></div>
              <div class="sm:col-span-2"><label class="text-sm font-medium text-gray-700">Endereço</label><input name="address" value="${c.address || ''}" class="input-field mt-1"></div>
              <div><label class="text-sm font-medium text-gray-700">Cidade</label><input name="city" value="${c.city || ''}" class="input-field mt-1"></div>
              <div><label class="text-sm font-medium text-gray-700">Estado</label><input name="state" value="${c.state || ''}" class="input-field mt-1"></div>
              <div><label class="text-sm font-medium text-gray-700">Instagram</label><input name="instagram" value="${c.instagram || ''}" class="input-field mt-1"></div>
              <div><label class="text-sm font-medium text-gray-700">Facebook</label><input name="facebook" value="${c.facebook || ''}" class="input-field mt-1"></div>
              <div><label class="text-sm font-medium text-gray-700">Cor Principal</label><input name="primary_color" type="color" value="${c.primary_color || '#6366f1'}" class="input-field mt-1 h-10"></div>
              <div><label class="text-sm font-medium text-gray-700">Cor Secundária</label><input name="secondary_color" type="color" value="${c.secondary_color || '#8b5cf6'}" class="input-field mt-1 h-10"></div>
            </div>
          </div>
          <div class="flex justify-end"><button type="submit" class="btn-primary">Salvar Configurações</button></div>
        </form>`;
    }

    async function saveSettings(e) {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(e.target));
      try { await api('/api/settings/company', { method: 'PUT', body: JSON.stringify(data) }); toast('Configurações salvas'); } catch (err) { toast(err.message, 'error'); }
    }

    // ===== USERS =====
    async function renderUsers() {
      const data = await api('/api/settings/users');
      document.getElementById('pageContent').innerHTML = `
        <div class="card overflow-hidden">
          <div class="table-container">
            <table class="w-full text-sm"><thead class="bg-gray-50 border-b"><tr><th class="text-left p-3 font-medium text-gray-600">Nome</th><th class="text-left p-3 font-medium text-gray-600 hidden sm:table-cell">Email</th><th class="text-left p-3 font-medium text-gray-600 hidden md:table-cell">Perfil</th><th class="text-center p-3 font-medium text-gray-600">Status</th><th class="text-center p-3 font-medium text-gray-600 hidden sm:table-cell">Último Acesso</th></tr></thead>
            <tbody>${data.users.map(u => `<tr class="border-b hover:bg-gray-50"><td class="p-3 font-medium">${u.name}</td><td class="p-3 text-gray-600 hidden sm:table-cell">${u.email}</td><td class="p-3 text-gray-600 hidden md:table-cell">${u.role_name || '-'}</td><td class="p-3 text-center">${statusBadge(u.status)}</td><td class="p-3 text-center text-xs hidden sm:table-cell">${u.last_login ? formatDate(u.last_login) : 'Nunca'}</td></tr>`).join('')}</tbody></table>
          </div>
        </div>`;
    }

    // ===== INITIALIZATION =====
    function toggleNotifications() { toast('Sem novas notificações', 'info'); }

    // Check auth
    if (!getToken()) { window.location.href = '/login'; }
    else {
      const user = getUser();
      const company = getCompany();
      if (user) {
        document.getElementById('userName').textContent = user.name;
        document.getElementById('userInitial').textContent = user.name?.charAt(0) || 'A';
      }
      if (company) document.getElementById('companyName').textContent = company.name;
      navigate('dashboard');
    }

    // Responsive sidebar
    if (window.innerWidth <= 768) {
      document.getElementById('sidebar').classList.add('collapsed');
      document.getElementById('mainContent').classList.add('expanded');
    }
  </script>
</body>
</html>
